{
  "name": "n8n-nodes-backchannel",
  "version": "0.1.0",
  "description": "n8n community node for Backchannel — atomic claimable task handoff between agents and workflows.",
  "keywords": [
    "n8n-community-node-package",
    "backchannel",
    "agent",
    "mcp",
    "claimable",
    "broadcast"
  ],
  "license": "MIT",
  "homepage": "https://backchannel.oakstack.eu",
  "author": {
    "name": "Oakstack",
    "email": "hello@oakstack.eu"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidiscarvalho/backchannel.git",
    "directory": "n8n_node"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "lint": "eslint nodes credentials",
    "format": "prettier --write nodes credentials"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BackchannelApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Backchannel/Backchannel.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "n8n-workflow": "^1.50.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
