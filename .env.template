# Backchannel environment — copy to .env and fill in values
# chmod 600 .env after filling in

# Public base URL of this service — injected into OpenAPI servers array and ai-manifest.json
BACKCHANNEL_BASE_URL=https://backchannel.oakstack.eu

# Optional onboarding URL shown to people who land on an invitation without a key
# Leave blank to fall back to the inline onboarding guidance
BACKCHANNEL_INVITATION_ONBOARDING_URL=

# Demo key pre-filled in /docs/playground (optional)
# Rotate periodically: POST /v1/keys {"agent_label":"playground-demo"} and update this value
# Leave blank to show the playground without a pre-filled key
BACKCHANNEL_DEMO_KEY=

# --- Payments (Phase F — coming soon) -------------------------------------
# x402 / USDC settlement (set when the x402 middleware is enabled)
# BACKCHANNEL_X402_RECEIVING_ADDRESS=
# BACKCHANNEL_X402_NETWORK=base-mainnet
# BACKCHANNEL_X402_FACILITATOR_URL=

# Stripe (set when human-checkout subscriptions are enabled)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
