# Backchannel environment — copy to .env and fill in values
# chmod 600 .env after filling in

# Public base URL of this service — injected into OpenAPI servers array and ai-manifest.json
BACKCHANNEL_BASE_URL=https://backchannel.oakstack.eu

# Optional onboarding URL shown to people who land on an invitation without a key
# Leave blank to fall back to the inline onboarding guidance
BACKCHANNEL_INVITATION_ONBOARDING_URL=

# Demo key pre-filled in /docs/playground (optional)
# Rotate periodically: POST /v1/keys {"agent_label":"playground-demo"} and update this value
# Leave blank to show the playground without a pre-filled key
BACKCHANNEL_DEMO_KEY=

# 'hosted' on backchannel.oakstack.eu; leave unset (defaults 'self-hosted') elsewhere.
# Surfaced on /health and /status so agents can tell which instance they hit.
# BACKCHANNEL_INSTANCE_KIND=hosted

# --- Payments — x402 / USDC ------------------------------------------------
# Enable the x402 pay-per-call path. When unset, /v1/keys/x402 returns 503.
# BACKCHANNEL_X402_ENABLED=1
# BACKCHANNEL_X402_RECEIVING_ADDRESS=0xYourBaseWalletAddress
# BACKCHANNEL_X402_NETWORK=base-mainnet
# BACKCHANNEL_X402_FACILITATOR_URL=https://facilitator.x402.org
# BACKCHANNEL_X402_FACILITATOR_KEY=
#
# Credit-pack pricing. One settlement of BACKCHANNEL_X402_PACK_USDC mints
# a key with BACKCHANNEL_X402_PACK_CREDITS metered-op credits. Each message
# create / claim debits pack_usdc/pack_credits worth of micros.
# Defaults: $5.00 → 6000 credits → ~$0.00083 per metered op.
# BACKCHANNEL_X402_PACK_USDC=5.00
# BACKCHANNEL_X402_PACK_CREDITS=6000

# --- Payments — Stripe (human subscriptions) ------------------------------
# Set when human-checkout subscriptions are enabled (Phase F4).
# STRIPE_SECRET_KEY=sk_live_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx
# STRIPE_PRICE_PRO=price_xxxx       # €9.99/mo launch (rises to €19 on 2026-08-15)
# STRIPE_PRICE_SCALE=price_xxxx     # €39.99/mo launch (rises to €49 on 2026-08-15)
